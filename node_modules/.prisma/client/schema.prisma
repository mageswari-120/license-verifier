// Prisma Schema — WDT License Verifier
// DB: MySQL (your Cloudways server)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify session storage (required by shopify-app-remix)
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// Core license table
model License {
  id             Int           @id @default(autoincrement())
  shopDomain     String // myshopify.com domain
  purchaseCode   String        @unique // ThemeForest purchase code (UUID)
  envatoItemId   Int // ThemeForest item ID
  envatoItemName String // Theme name e.g. "Lollipop"
  buyerUsername  String // Envato buyer username
  licenseType    String // "Regular License" or "Extended License"
  soldAt         DateTime // Original purchase date from Envato
  supportedUntil DateTime // Support expiry from Envato
  licenseKey     String        @unique // Our generated license key (UUID)
  status         LicenseStatus @default(ACTIVE)
  storefront     String        @default("buddhathemes") // which TF storefront
  verifiedAt     DateTime      @default(now())
  lastCheckedAt  DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  downloads     Download[]
  supportTokens SupportToken[]

  @@index([shopDomain])
  @@index([purchaseCode])
  @@index([licenseKey])
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}

// Track theme download events
model Download {
  id           Int      @id @default(autoincrement())
  licenseId    Int
  version      String // e.g. "2.1.0"
  downloadedAt DateTime @default(now())
  ipAddress    String?

  license License @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

// Support access tokens (time-limited)
model SupportToken {
  id        Int      @id @default(autoincrement())
  licenseId Int
  token     String   @unique @default(uuid())
  expiresAt DateTime // 30 days from generation
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  license License @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

// ThemeForest items registry (buddhathemes catalog)
model ThemeItem {
  id          Int      @id // ThemeForest item ID (the actual numeric ID)
  name        String // "Lollipop - Shopify Theme"
  slug        String // "lollipop"
  storefront  String   @default("buddhathemes")
  downloadUrl String? // Latest version download URL
  version     String? // Current version e.g. "2.1.0"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
