generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model License {
  id             Int            @id @default(autoincrement())
  shopDomain     String
  purchaseCode   String         @unique
  envatoItemId   Int
  envatoItemName String
  buyerUsername  String
  licenseType    String
  soldAt         DateTime
  supportedUntil DateTime
  licenseKey     String         @unique
  status         LicenseStatus  @default(ACTIVE)
  storefront     String         @default("buddhathemes")
  verifiedAt     DateTime       @default(now())
  lastCheckedAt  DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  downloads      Download[]
  supportTokens  SupportToken[]

  @@index([shopDomain])
  @@index([purchaseCode])
  @@index([licenseKey])
}

model Download {
  id           Int      @id @default(autoincrement())
  licenseId    Int
  version      String
  downloadedAt DateTime @default(now())
  ipAddress    String?
  license      License  @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

model SupportToken {
  id        Int      @id @default(autoincrement())
  licenseId Int
  token     String   @unique @default(uuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  license   License  @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

model ThemeItem {
  id          Int      @id
  name        String
  slug        String
  storefront  String   @default("buddhathemes")
  downloadUrl String?
  version     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}
