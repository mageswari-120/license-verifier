# Get from: build.envato.com → My Apps → Create Personal Token
ENVATO_PERSONAL_TOKEN=your_buddhathemes_envato_token

# ThemeForest Item IDs for buddhathemes (add all your Shopify theme IDs)
# Comma-separated list of valid item IDs
BUDDHATHEMES_ITEM_IDS=12345678,87654321

# License Key Secret (for generating signed license keys)
